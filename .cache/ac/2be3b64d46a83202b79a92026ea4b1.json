der-language-popup__item\">\n                            <button class=\"header-language-popup__button header-language-popup__button--active\" type=\"button\" id=\"English\">English</button>\n                        </li>\n                        <li class=\"header-language-popup__item\">\n                            <button class=\"header-language-popup__button\" type=\"button\" id=\"German\">German</button>\n                        </li>\n                        <li class=\"header-language-popup__item\">\n                            <button class=\"header-language-popup__button\" type=\"button\" id=\"Ukrainian\">Ukrainian</button>\n                        </li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"header__registration-block\">\n                <button type=\"button\" class=\"header__registration-signin\">Sign in</button>\n                <button type=\"button\" class=\"header__registration-start\">\n                    Start Learning\n                    <img src=\"/9632b13b2c2758c19e95abb9160096d0.svg\" alt=\"icon\" class=\"header__registration-start-icon\">\n                </button>\n            </div>\n            <!-- <div class=\"header-registration-popup\"> \n\n            </div> -->\n        </div>\n    </header>\n    <main class=\"main\">\n        <div class=\"container main__content\">\n            <div class=\"hero\">\n                <div class=\"hero__info\">\n                    <h1 class=\"hero__title\">\n                        Learn languages \n                            & \n                        Remember forever\n                    </h1>\n                    <h3 class=\"hero__untertitle\">\n                        A platform that turns words into \n                        knowledge — powered by the science of \n                        memory\n                    </h3>\n                    <a href=\"#\" class=\"hero__start-button\">\n                        Start Now\n                        <img src=\"/9632b13b2c2758c19e95abb9160096d0.svg\" alt=\"icon\" class=\"hero__start-icon\">\n                    </a>\n                </div>\n                <img src=\"/fe6ea95e9e710ec2a86cd5ada442b575.jpg\" alt=\"Imahe\" class=\"hero__image\">\n            </div>\n            <h1 class=\"quote\">\n                Less memorizing\n                More understanding\n            </h1>\n            <div class=\"features\">\n                <h2 class=\"features__title\">Features</h2>\n                <ul class=\"features__item-box\">\n                    <li class=\"features__item\">\n                        <img src=\"/184eba9f8ce75e781b4f45789d9499ad.jpg\" alt=\"Ebbinghaus\" class=\"features__item-img\">\n                        <h4 class=\"features__itme-text\">\n                            Based on the Ebbinghaus \n                            method\n                        </h4>\n                    </li>\n                    <li class=\"features__item\">\n                        <img src=\"/77904d03a4ce6045e5f51ceae1b50ee4.jpg\" alt=\"One Place\" class=\"features__item-img\">\n                        <h4 class=\"features__itme-text\">\n                            All in one place\n                        </h4>\n                    </li>\n                    <li class=\"features__item\">\n                        <img src=\"/0c4deb8e2dfaac546a1ab4d7f1ebecc0.jpg\" alt=\"Maskot\" class=\"features__item-img\">\n                        <h4 class=\"features__itme-text\">\n                            Made by a learner, for \n                            learners\n                        </h4>\n                    </li>\n                </ul>\n            </div>\n            <div class=\"how-it-works\">\n                <h2 class=\"how-it-works__title\">How it works</h2>\n                <div class=\"how-it-works__content\">\n                    <div class=\"how-it-works__number-group\">\n                        <h3 class=\"how-it-works__number\">1</h3>\n                        <img src=\"/e6272b19fbfed7c40289d34b5cac3397.svg\" alt=\"line\" class=\"how-it-works__line\">\n                        <h3 class=\"how-it-works__number\">2</h3>\n                        <img src=\"/e6272b19fbfed7c40289d34b5cac3397.svg\" alt=\"line\" class=\"how-it-works__line\">\n                        <h3 class=\"how-it-works__number\">3</h3>\n                        <img src=\"/e6272b19fbfed7c40289d34b5cac3397.svg\" alt=\"line\" class=\"how-it-works__line\">\n                        <h3 class=\"how-it-works__number\">4</h3>\n                    </div>\n                </div>\n                <div class=\"how-it-works__blocks-group\">\n                    <div class=\"how-it-works__block\">\n                        <h4 class=\"how-it-works__block-title\">Add</h4>\n                        <img src=\"/8cc8a2a098f5342e66b06234552c490f.svg\" alt=\"Add\" class=\"how-it-works__block-img\">\n                    </div>\n                    <div class=\"how-it-works__block\">\n                        <h4 class=\"how-it-works__block-title\">Learn</h4>\n                        <img src=\"/cf8e17b8b0d00c0c32f3f128b8e7ccab.svg\" alt=\"Learn\" class=\"how-it-works__block-img\">\n                    </div>\n                    <div class=\"how-it-works__block\">\n                        <h4 class=\"how-it-works__block-title\">Repeat</h4>\n                        <img src=\"/bb84eecab99273d5628b2407c17cdcef.svg\" alt=\"Repeat\" class=\"how-it-works__block-img\">\n                    </div>\n                    <div class=\"how-it-works__block\">\n                        <h4 class=\"how-it-works__block-title\">Remember</h4>\n                        <img src=\"/699416ba8efef7fadb0b2ae6e4915718.svg\" alt=\"Remember\" class=\"how-it-works__block-img\">\n                    </div>\n                </div>\n            </div>\n            <div class=\"vwa\">\n                <h2 class=\"vwa__title\">VWA</h2>\n                <div class=\"vwa__content\">\n                    <div class=\"vwa__author-group\">\n                        <img src=\"/ffd2a32e5d0d24eebcdfcb3da594e323.jpg\" alt=\"Author with mascot\" class=\"vwa__author-img\">\n                        <div class=\"vwa__author-info\">\n                            <h4 class=\"vwa__author-title\">Yehor Kantsyr</h4>\n                            <p class=\"vwa__author-subtitle\">(Creator of LingoIQ)</p>\n                        </div>\n                    </div>\n                    <p class=\"vwa__pharagrph\">\n                        Hi! I’m Yehor, and LingoIQ is my VWA project.\n                        <br>\n                        I created this site to make language learning <b>simpler and more structured.</b>\n                        Here, you can find words, grammar rules, and learning tools <b>all in one place.</b>\n                        <br>\n                        The site includes a program I developed using <b>Hermann Ebbinghaus’ spaced repetition method</b> to help you remember words efficiently.\n                        It’s designed for students, migrants, and anyone eager to learn languages, offering <b>clear structures and easy navigation.</b>\n                        <br>\n                        With LingoIQ, I want to give everyone the same opportunity I had: a clear path to mastering a new language.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </main>\n    <footer class=\"footer container\">\n        <a href=\"#\" class=\"footer-panel__logo-link\">\n            <img src=\"/c5c8c21b7ca2c1915e80ab79b7cc8964.svg\" alt=\"logo\" class=\"footer-panel__logo-img\">\n        </a>\n        <div class=\"footer__social-media\">\n            <a href=\"#\" class=\"footer__social-media-link\">\n                <img src=\"/7c8d573dbb3f42509cb7143fd47b8ee1.svg\" alt=\"Youtube\" class=\"footer__social-media-icon\">\n            </a>\n            <a href=\"#\" class=\"footer__social-media-link\">\n                <img src=\"/e35